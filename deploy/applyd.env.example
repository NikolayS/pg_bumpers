# pg_bumpers applyd — example runtime configuration (SPEC §3/§4; issue #67, S5).
#
# `pgb-applyd` (crates/applyd, binary `pgb-applyd`) is the WRITE-PATH DAEMON: a
# long-lived process that owns the propose→dry_run→request_elevation→approve→apply
# lifecycle over the merged grant-gated apply floor (`guarded_apply_with_grant`),
# and exposes it over a **Unix-domain socket** speaking line-delimited JSON-RPC
# 2.0. The MCP server's ApplydCore (TS) wires to this socket for writes; reads go
# through the proxy, NOT here. Copy to an out-of-tree `.env` and load it
# (e.g. `set -a; . ./applyd.env; set +a; pgb-applyd`).
#
# SECURITY: the SOCKET is the boundary, NOT the MCP server. It is owner-only (the
# parent dir is created 0700 and the socket chmod'd 0600) and is NOT a TCP port,
# NOT agent-reachable. The `apply` RPC takes only {proposal_id, confirm_rows,
# confirm_token}; the daemon RE-DERIVES the live request (statement/role/session)
# from its OWN stored proposal record, so the agent can never swap what is applied.
#
# SECRETS: the backend/audit-key placeholders here are DEV values matching the
# local-stack. Production resolves them from the secret store (SPEC §4 "Secrets"),
# never from a committed file.

# --- the write-path socket ---------------------------------------------------
# The Unix-domain socket pgb-applyd binds. The parent dir is created 0700 and the
# socket chmod'd 0600 (owner-only). The MCP ApplydCore connects here for writes.
PGB_APPLYD_SOCKET=/var/run/pg_bumpers/applyd.sock

# --- the apply-time trust root (the approver's public key) -------------------
# PGB_APPROVER_PUBKEY — the human approver's Ed25519 VERIFYING key, hex (32 bytes
# = 64 hex chars). This is the apply-time trust root the §4 floor verifies signed
# grants against; the signing (private) key NEVER enters the daemon/agent path —
# it is presented out-of-band by the operator at `approve`. REQUIRED (no default).
PGB_APPROVER_PUBKEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# --- policy / budgets --------------------------------------------------------
# The clone.provider + pitr.enabled bits are bridged from policy.yaml onto the
# apply (the single source of truth).
PGB_POLICY_PATH=crates/policy/policy.example.yaml
PGB_POLICY_ROLE=analytics

# --- backend (PG18 PRIMARY as the constrained DML-only applier role) ---------
# The resident apply Client connects here to run the guarded apply on the primary.
# NEVER the founder's cluster on 5432; the local-stack primary is 54321.
#
# PGB_BACKEND_ROLE is the CONSTRAINED, DML-ONLY applier role `pgb_applier` (S5 #77),
# NOT the read-only WALL role `pgb_agent` (which cannot write so cannot carry the apply
# path) and NOT the Postgres SUPERUSER. `pgb_applier` has SELECT/INSERT/UPDATE/DELETE on
# the application tables and CANNOT DDL (no CREATE/ALTER/DROP; NOSUPERUSER) — defense-in-
# depth at the DB level under the application-layer §4 apply floor. RUNNING applyd AS THE
# SUPERUSER IS STRONGLY DISCOURAGED: a bug in the apply path under superuser could issue
# arbitrary DDL; under `pgb_applier` the DB itself bounds the blast radius to row DML.
PGB_BACKEND_HOST=127.0.0.1
PGB_BACKEND_PORT=54321
PGB_BACKEND_DB=postgres
PGB_BACKEND_ROLE=pgb_applier
# REQUIRED (no default literal in the binary); DEV placeholder matching the
# local-stack constrained applier role (deploy/sql/10_hardened_role.sql).
PGB_BACKEND_PASSWORD=pgb_applier_dev_pw

# --- audit `_meta` chain (SPEC §3/§4/§10.9) ----------------------------------
# The daemon hash-chains the FULL lifecycle (request_elevation / grant_signed /
# apply_committed) AND every refused propose/dry_run (S5 #76 item 1) into the SAME
# shared, anchored `_meta` chain as the proxy. All REQUIRED (no literal defaults in
# the binary; fail-closed). See proxy.env.example for the field-by-field rationale.
PGB_META_DSN=host=127.0.0.1 port=55432 user=pgb_audit_writer password=pgb_audit_writer_dev_pw dbname=postgres
# COHERENT SINGLE-OWNER ANCHOR (S5 #76 item 3): the proxy is the anchor OWNER and
# applyd is VERIFY-ONLY over the ONE shared chain. For applyd to verify the
# OWNER's anchored-head signature, the signing key + anchor file MUST be IDENTICAL
# to the proxy's. Keep these three lines in lock-step with proxy.env.example.
PGB_AUDIT_SIGNING_KEY=pgb-audit-signing-key-dev-000001
PGB_ANCHOR_PATH=/var/lib/pg_bumpers/audit/anchor.worm
PGB_ANCHOR_INTERVAL_MS=60000
# This binary's anchor role over the shared chain. applyd defaults to `verify`
# (verify-only on boot, never anchors — fail-closed on a head mismatch). The proxy
# is the `owner` (the sole anchorer). Override only to re-designate the owner.
PGB_ANCHOR_ROLE=verify
