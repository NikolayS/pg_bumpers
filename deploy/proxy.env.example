# pg_bumpers proxy — example runtime configuration (SPEC §3 layer 2, §7 S1).
#
# The proxy (crates/proxy, binary `pgb-proxy`) is the inline, agent-only
# enforcement endpoint: it terminates the agent's SCRAM-SHA-256 + TLS connection,
# originates a backend session as the hardened WALL role, and enforces
# extended-protocol-only / read-only / byte-row cutoff / statement_timeout, with
# a hash-chained audit of every statement. Copy to an out-of-tree `.env` and load
# it (e.g. `set -a; . ./proxy.env; set +a; pgb-proxy`).
#
# SECRETS: agent/backend passwords here are DEV placeholders matching the
# local-stack WALL role (deploy/sql/10_hardened_role.sql). Production resolves
# them from the secret store (SPEC §4 "Secrets"), never from a committed file.

# --- agent-facing listener ---------------------------------------------------
# The endpoint the agent (MCP / raw client) connects to. Bind to the address the
# network policy permits; the §3 layer-0 boundary makes this the only path in.
PGB_PROXY_LISTEN=127.0.0.1:6432

# TLS on the agent endpoint (rustls). Both set ⇒ TLS on. PEM-encoded cert chain
# + private key.
PGB_PROXY_TLS_CERT=/etc/pg_bumpers/proxy/server.crt
PGB_PROXY_TLS_KEY=/etc/pg_bumpers/proxy/server.key

# TLS-required posture. Default: TLS is REQUIRED whenever cert+key are configured
# (no silent cleartext downgrade) — a client SSLRequest is upgraded, and a direct
# cleartext StartupMessage is rejected. Set `false` for the EXPLICIT dev-only
# no-TLS mode (plaintext); setting `true` with no cert/key is a hard error.
PGB_PROXY_REQUIRE_TLS=true

# The SCRAM credential the proxy verifies for connecting agents.
# PGB_AGENT_PASSWORD is REQUIRED (no default literal in the binary); the value
# below is a DEV placeholder matching the local-stack WALL role.
PGB_AGENT_USER=pgb_agent
PGB_AGENT_PASSWORD=pgb_agent_dev_pw

# --- backend (PG18 as the WALL role) -----------------------------------------
# The ONLY network path to the DB is this proxy (SPEC §3 layer 0). Point at the
# primary as the hardened agent role. NEVER the founder's cluster on 5432; the
# local-stack primary is 54321.
PGB_BACKEND_HOST=127.0.0.1
PGB_BACKEND_PORT=54321
PGB_BACKEND_DB=postgres
PGB_BACKEND_ROLE=pgb_agent
# REQUIRED (no default literal in the binary); DEV placeholder matching the
# local-stack WALL role below.
PGB_BACKEND_PASSWORD=pgb_agent_dev_pw

# --- policy / budgets --------------------------------------------------------
# Per-role byte/row budgets come from policy.yaml (the single source of truth).
PGB_POLICY_PATH=crates/policy/policy.example.yaml
PGB_POLICY_ROLE=analytics

# Injected statement_timeout (ms) on every backend session — an un-foolable DoS
# backstop (catches the classifier blind spot, e.g. pg_sleep).
PGB_STATEMENT_TIMEOUT_MS=30000

# --- audit `_meta` chain (SPEC §3/§4/§10.9) ----------------------------------
# The proxy persists every gate verdict into ONE shared, hash-chained `_meta`
# table and anchors its head to an external WORM. All REQUIRED (no literal
# defaults in the binary; fail-closed).
#
# PGB_META_DSN — the `_meta` WRITER DSN (keyword/value). Authenticate as the
#   audit-writer role (pgb_audit_writer), NEVER the audited agent.
PGB_META_DSN=host=127.0.0.1 port=55432 user=pgb_audit_writer password=pgb_audit_writer_dev_pw dbname=postgres
# PGB_AUDIT_SIGNING_KEY — the chain-head signing key material (the dev secret-
#   store seam; production addresses a KMS key version, separated from the DB
#   operator per §10.9). DEV placeholder below. SINGLE-OWNER ANCHOR (S5 #76 item 3):
#   this key signs the anchored head; applyd (verify-only) MUST be configured with
#   the IDENTICAL key + anchor file to verify it. Keep in lock-step with
#   applyd.env.example.
PGB_AUDIT_SIGNING_KEY=pgb-audit-signing-key-dev-000001
# PGB_ANCHOR_PATH — the DURABLE, file-backed WORM anchor path. The anchored head
#   is persisted here so it SURVIVES A RESTART; on boot the proxy verifies the
#   `_meta` chain against the PRIOR durable head BEFORE re-anchoring, catching an
#   offline full-chain rewrite ACROSS a restart (fail-closed). The file stand-in
#   models object-lock / transparency-log retention the operator cannot rewrite;
#   production swaps in S3 Object Lock (compliance mode) or a transparency log.
#   SHARED across the proxy (owner) and applyd (verify-only) — same path.
PGB_ANCHOR_PATH=/var/lib/pg_bumpers/audit/anchor.worm
# PGB_ANCHOR_INTERVAL_MS — the WORM anchoring cadence in millis (default 60000).
PGB_ANCHOR_INTERVAL_MS=60000
# PGB_ANCHOR_ROLE — this binary's role over the ONE shared anchored chain (S5 #76
#   item 3). The proxy is the `owner` (the SOLE anchorer); applyd is `verify` (it
#   verifies the owner's anchored head on boot, fail-closed on a mismatch, but
#   never anchors). Exactly one owner over the shared chain — no two-anchorer race.
PGB_ANCHOR_ROLE=owner
