# pg_bumpers warden — example runtime configuration (SPEC §4 "Warden", §10.10).
#
# `pgb-warden` (crates/warden, binary `pgb-warden`) is the live, OUT-OF-BAND
# watchdog: it polls the primary's `pg_stat_activity` and kills AGENT-tagged
# runaway backends, alarms on replication-slot WAL retention, trips a breaker on
# lag/runaway volume, and audits every action to the SAME anchored `_meta` chain
# the proxy/applyd use. It is NOT in the agent's connection path — it is a
# separate supervisor. Copy to an out-of-tree `.env` and load it
# (e.g. `set -a; . ./warden.env; set +a; pgb-warden`).
#
# SECRETS: the admin/audit-writer passwords here are DEV placeholders matching the
# local-stack roles. Production resolves them from the secret store (SPEC §4
# "Secrets"), never from a committed file.

# --- the OPERATIONAL THRESHOLDS live in policy.yaml, NOT here -----------------
# The warden's kill/alarm/breaker thresholds (poll cadence, runaway-kill timeout,
# slot/lag ceilings, trip count, cooldown) are read from the `warden:` SECTION of
# the policy file at PGB_POLICY_PATH (crates/warden/src/thresholds.rs
# `WardenThresholds::from_policy_yaml`, loaded fail-closed at startup). They are
# NOT environment variables — see the documented `warden:` block in
# crates/policy/policy.example.yaml. A missing `warden:` section falls back to the
# conservative built-in default; a present-but-disabling value is REJECTED.
PGB_POLICY_PATH=crates/policy/policy.example.yaml

# --- backend (PG18 PRIMARY the warden polls + terminates) --------------------
# The admin role the warden observes/kills with. NEVER the founder's cluster on
# 5432; the local-stack primary is 54321. The warden tags its own sessions
# (application_name=pgb_warden_admin) so it never observes or kills itself.
PGB_BACKEND_HOST=127.0.0.1
PGB_BACKEND_PORT=54321
PGB_BACKEND_DB=postgres
# A privileged maintenance role able to read pg_stat_activity and pg_terminate_backend
# the agent-tagged runaways. REQUIRED (no default literal); fail-closed on a missing
# password (the warden ships no credential literals).
PGB_WARDEN_ADMIN_ROLE=postgres
PGB_WARDEN_ADMIN_PASSWORD=postgres_dev_pw

# --- audit `_meta` chain (the warden appends as the WRITER role) --------------
# The warden writes its kill/alarm decisions to the SAME anchored `_meta` chain as
# the proxy/applyd, as the INSERT-capable pgb_audit_writer (never the agent role —
# "the audited cannot write audit"). The audit DB defaults to PGB_BACKEND_DB if
# unset.
PGB_AUDIT_DB=postgres
PGB_AUDIT_WRITER_ROLE=pgb_audit_writer
# REQUIRED (no default literal); DEV placeholder matching the local-stack writer role.
PGB_AUDIT_WRITER_PASSWORD=pgb_audit_writer_dev_pw
